{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Monitoraggio linea imbottigliamento vino — Riempitrice e Tappatrice",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🍷 RIEMPITRICE — valori in tempo reale",
      "type": "row"
    },

    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "temperatura_liquido_C" },
            "properties": [
              { "id": "displayName", "value": "Temperatura (°C)" },
              { "id": "unit", "value": "celsius" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 28 }, { "color": "red", "value": 33 }] } },
              { "id": "custom.thresholdsStyle", "value": { "mode": "line" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pressione_circuito_bar" },
            "properties": [
              { "id": "displayName", "value": "Pressione (bar)" },
              { "id": "unit", "value": "pressurebar" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "bottiglie_riempite_pz_min" },
            "properties": [
              { "id": "displayName", "value": "Bottiglie (pz/min)" },
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Riempitrice — Tutti i sensori",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"riempitrice\")\n  |> filter(fn: (r) => r._field == \"temperatura_liquido_C\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"riempitrice\")\n  |> filter(fn: (r) => r._field == \"pressione_circuito_bar\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"riempitrice\")\n  |> filter(fn: (r) => r._field == \"bottiglie_riempite_pz_min\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "C"
        }
