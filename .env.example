# Copia in ".env" (cp .env.example .env) e compila. Non committare ".env".

# Grafana — login: admin / <questo valore>
GF_SECURITY_ADMIN_PASSWORD=admin

# InfluxDB — devono combaciare con il service "influxdb" in docker-compose.yml
INFLUXDB_ORG=farm
INFLUXDB_BUCKET=farm_raw
INFLUXDB_TOKEN=farm-token

# Slack — Incoming Webhook (vuoto = notifiche disattivate)
SLACK_WEBHOOK_URL=
