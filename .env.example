# Copia questo file in ".env" e compila i valori.
#   cp .env.example .env
#
# Docker Compose legge automaticamente ".env" nella stessa cartella.
# NON committare ".env" (contiene segreti): aggiungilo a .gitignore.

# ─── Grafana ──────────────────────────────────────────────────────────────
# Password dell'utente admin di Grafana (login: admin / <questo valore>).
GF_SECURITY_ADMIN_PASSWORD=admin

# ─── InfluxDB (usati dal datasource e dalle alert rules provisioned) ──────
# Devono corrispondere all'org/token/bucket dell'InfluxDB deployato
# (vedi service "influxdb" in docker-compose.yml).
INFLUXDB_ORG=farm
INFLUXDB_BUCKET=farm_raw
INFLUXDB_TOKEN=farm-token

# ─── Slack (notifiche allarmi) ────────────────────────────────────────────
# Incoming Webhook della tua Slack App. Lascia vuoto per disabilitare l'invio.
# Es.: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXX
SLACK_WEBHOOK_URL=
