      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"sensors\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"riempitrice\" and r._field == \"temperatura_liquido_C\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: if r._value > 28.0 then 1 else 0 }))",
        "refId": "A"
